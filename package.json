{
  "name": "dual-arm-digital-twin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "tsx server/server.ts",
    "dev": "concurrently -k -n API,UI -c yellow,cyan \"tsx watch server/server.ts\" \"ng serve\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run test:server && npm run test:frontend",
    "test:server": "vitest run server",
    "test:frontend": "ng test --watch=false",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --ignoreConfig --noEmit --strict --skipLibCheck --module nodenext --moduleResolution nodenext --target es2022 --allowImportingTsExtensions server/server.ts server/simulation.ts"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "three": "^0.184.0",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.0",
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
